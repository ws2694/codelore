# Elasticsearch (Elastic Cloud)
ES_URL=https://your-deployment.es.us-central1.gcp.elastic.cloud:443
ES_API_KEY=your-elasticsearch-api-key

# Kibana (Agent Builder)
KIBANA_URL=https://your-deployment.kb.us-central1.gcp.elastic.cloud:443
KIBANA_API_KEY=your-kibana-api-key

# GitHub OAuth (register at https://github.com/settings/applications/new)
# Set callback URL to: http://localhost:3000/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub (optional — fallback if not using OAuth)
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO=owner/repo

# App
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
